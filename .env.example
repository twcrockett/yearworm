# Copy this file to .env and fill in values before running locally.
# .env is gitignored — never commit real values.

# Required: stable secret key for Flask sessions
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Phase 4 — admin interface (set before building admin routes)
ADMIN_PASSWORD=change-me

# Phase 4 — email reminders via SendGrid
SENDGRID_API_KEY=
ADMIN_EMAIL=
